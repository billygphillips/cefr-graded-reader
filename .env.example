# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets

# Anthropic (Claude) — get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenRouter (access to multiple models) — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# OpenAI (optional, if using directly) — get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# ElevenLabs (audio generation, stretch goal) — get key at https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-key-here
